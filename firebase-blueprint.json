{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
